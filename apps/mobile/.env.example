# Physical Android/iPhone on Wi‑Fi — use your PC's LAN IPv4 (ipconfig on Windows).
# Phone and PC must be on the same network. Restart Expo after changing.
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3333

# USB debugging (Android): you can skip .env if you run from repo root:
#   npm run android:reverse
# Then reload the app — it uses http://127.0.0.1:3333 on the phone.
