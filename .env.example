# Copy to apps/api/.env
OPENAI_API_KEY=sk-...
# ChatGPT 4o mini (default for POST /chat)
OPENAI_MODEL=gpt-4o-mini
# Speech-to-text for voice orders (default: gpt-4o-mini-transcribe)
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
PORT=3333
HOST=0.0.0.0

# Optional — LiveKit realtime voice (POST /sessions/:id/livekit/token)
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
